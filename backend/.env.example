NODE_ENV=development
PORT=4000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# HiveMQ Cloud (MQTT v5 over TLS)
HIVEMQ_URL=mqtts://your-cluster.hivemq.cloud:8883
HIVEMQ_USER=your-mqtt-user
HIVEMQ_PASS=your-mqtt-pass

# Solana (primary chain)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_KEYPAIR=[1,2,3,...]  # JSON array of secret key bytes, or base58 string

# Lisk (secondary chain — monthly only)
LISK_RPC_URL=https://testnet-service.lisk.com
LISK_PASSPHRASE=your-lisk-passphrase

# Alerta
ALERTA_API_KEY=your-alerta-api-key
ALERTA_BASE_URL=https://alerta.example.com/api
ALERTA_WEBHOOK_SECRET=your-webhook-hmac-secret

# Firebase Cloud Messaging
FCM_PROJECT_ID=your-firebase-project
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Resend email
RESEND_API_KEY=your-resend-key
RESEND_FROM=AURA <alerts@aura.app>

# Observability + auth
SENTRY_DSN=
JWT_SECRET=your-jwt-secret

# Frontend
FRONTEND_URL=http://localhost:3000
